<%@taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><%@ page contentType="text/html;charset=UTF-8" language="java" %><html><head>    <title>Title</title>    <link rel="stylesheet" href="member.css">    <script>       function deleteMember(nooo) {          let ok = confirm("really?");          if(ok) {              location.href='del?num=' + nooo;          }       }       function updateMemberName(nnn, naaame) {           let name = prompt('edit?', naaame)           // alert(name);           if(name != "" && name != null) {               location.href = 'update?num=' + nnn + '&n=' + name;           }       }    </script></head><body><h2 style="color: #ffb7b2;">🍭 Member List 🍭</h2><table class="member-table">    <thead>    <tr>        <th>NAME</th>        <th>AGE</th>    </tr>    </thead>    <tbody>    <c:forEach var="m" items="${members}">        <tr class="member-row">           <td><span onclick="updateMemberName('${m.no}', '${m.name}')">${m.name}</span></td>            <td>${m.age}           <div><button onclick="deleteMember(${m.no})">del</button></div></td>        </tr>    </c:forEach>    </tbody></table></body></html>