<%@ page contentType="text/html;charset=UTF-8" language="java" %><%--접두어 마음대로 면경 가능 but 업계에서 'core' 사용 시에 'c;로 쓰기로 약속함--%><%@taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><html><head>    <title>Title</title>    <style>        /* 1. 빨간 테두리 박스 내부의 첫 번째 자식(헤더) 선택 */        div[style*="border: 2px solid red"] > div:first-child {            background-color: #f8f9fa;            border-bottom: 2px solid #eee;            font-weight: bold;            color: #333;        }        /* 2. 빨간 테두리 박스 내부의 모든 'item' 클래스 정렬 */        .item {            padding: 10px;            flex: 1; /* 모든 칸을 균등하게 */            text-align: center;            border-right: 1px solid #eee; /* 칸 구분선 */        }        /* 3. 마지막 칸은 구분선 제거 */        .item:last-child {            border-right: none;        }        /* 4. 데이터 행(item-row)에 대한 마우스 호버 효과 */        .item-row {            border-bottom: 1px solid #f1f1f1;            transition: background-color 0.2s;        }        .item-row:hover {            background-color: #fff9f0;        }    </style></head><body>  <h1>당신의 나이는 ${age} 입니다.</h1><%--     1. jsp 표준 액션태그 : include    2. jstl (사제) : jstl.jar가 필요    20갈 이상이면 존댓말 / 이상이면 반말--%><c:if test="${age >= 20}">    <h1>안녕하세요</h1></c:if><c:if test="${age < 20}">    <h1>안녕</h1></c:if><%--  otherwise 단독으로는 사용 불가 --%><%--<c:otherwise>asd</c:otherwise>--%><%-- if, else if, else --%><c:choose>    <c:when test="${age > 20}">        어서오세요~~    </c:when>    <c:when test="${age > 10}">        어서와~~    </c:when>    <c:otherwise>        안녕~~    </c:otherwise></c:choose><hr><c:forEach begin="1" end="3" step="2">    <h1>ㅎㅂㅎ/</h1></c:forEach><%--  역순은 안됨 (step에 음수가 안들어감) / 다른 방식 사용해야 함--%><c:forEach begin="1" end="${age}" var="aa" step="1">    ${aa}</c:forEach><hr><c:forEach items="${ar}" var="aa">    ${aa}</c:forEach><hr><%--  배열 돌릴 때는 items 코드 사용하면 됨 --%><c:forEach items="${menus}" var="menu">    ${menu.name} / ${menu.price}</c:forEach><hr><div style="border: 2px solid red; width: 300px">    <div style="display: flex">        <div class="item name">번호</div>        <div class="item name">메뉴명</div>        <div class="item name">가격</div>    </div>    <c:forEach items="${menus}" var="menu" varStatus="st">    <div class="item-row" style="display: flex">        <div class="item index">${st.index}</div>        <div class="item name">${menu.name}</div>        <div class="item name">${menu.price}</div>    </div>    </c:forEach></div><hr><c:forEach var="i" begin="1" end="10" varStatus="st"><%--  11 - i  // 아래와 결과값 동일 --%>    ${st.end + 1 - i}</c:forEach><hr><c:forEach var="i" begin="1" end="10">    <c:set var="v" value="${11-i}"></c:set>    <c:out value="${v}"></c:out></c:forEach></body></html>