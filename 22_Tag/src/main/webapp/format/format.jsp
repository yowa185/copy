<%@ page contentType="text/html;charset=UTF-8" language="java" %><%-- format 코드 접두어 약속은 fmt--%><%@taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><html><head>    <title>Title</title>  <style>    /* 헤더와 각 행을 가로로 정렬 */    .snack-row {      display: flex;      border-bottom: 1px solid #606060;      align-items: center;    }    /* 마지막 줄 테두리 제거 */    .snack-row:last-child {      border-bottom: none;    }    /* 개별 칸 스타일 */    .snack {      padding: 12px 10px;      text-align: center;      font-size: 14px;    }    /* 열별 너비 비율 조정 */    .col-num   { width: 50px; color: #888; }   /* 번호 */    .col-name  { flex: 2; text-align: left; padding-left: 20px; } /* 과자 이름 */    .col-price { flex: 1; font-weight: bold; color: #2b8a3e; }    /* 가격 */    .col-date  { flex: 1.5; color: #666; font-size: 13px; }       /* 날짜 */    /* 마우스 올렸을 때 효과 */    .snack-row:not(.snack-header):hover {      background-color: #f8f9fa;    }  </style></head><body><h1>format jsp 영역~~~~</h1>${a}<hr><%--돈처럼 중간에 컴마 넣어줌--%><fmt:formatNumber value="${a}"></fmt:formatNumber><hr><%--앞에 원 기호 붙여줌 (currencySymbol="$" 안넣으면 기본원 '원')--%><fmt:formatNumber value="${a}" type="currency" currencySymbol="$"></fmt:formatNumber><hr><%--기본적으로 반올림 처리된 상태, '/'는 단일태그로 쓰겠다는 의미(셀프 클로징)--%><fmt:formatNumber value="${b}" /><hr><%--자동 퍼센트 변환--%><fmt:formatNumber value="${b}" type="percent"/><hr><%--반올림 처리 하기 싫으면 아래 형식으로.(0은 0갯수만큼 자릿수를 만들어주고 자릿수에 숫자가 없을 땐 0으로 채워줌)--%><fmt:formatNumber value="${b}" pattern="0.00000" /><hr><fmt:formatNumber value="${b}" pattern="#.#####" /><hr><fmt:formatNumber value="${b}" pattern="0,00.000" /><hr><fmt:formatNumber value="${b}" pattern="#,##.###" /><hr><%--#은 뒤에서부터 센다...--%><fmt:formatNumber value="${c}" pattern="#,###.00" /><hr>${d}<hr><%--날짜 데이터 예쁘게 변환(yyyy.mm.dd)--%><fmt:formatDate value="${d}" /><hr><%--날짜 데이터 예쁘게 변환(yy.mm.dd)--%><fmt:formatDate value="${d}" type="date" dateStyle="short" /><hr><%--날짜 데이터 예쁘게 변환(yyyy년 mm월 dd일)--%><fmt:formatDate value="${d}" type="date" dateStyle="long" /><hr><%--시간 데이터 예쁘게 변환--%><fmt:formatDate value="${d}" type="time" timeStyle="short" /><hr><fmt:formatDate value="${d}" type="time" timeStyle="long" /><hr><%--같이 변환도 가능--%><fmt:formatDate value="${d}" type="both" dateStyle="long" timeStyle="short" /><hr><fmt:formatDate value="${d}" type="both" dateStyle="short" timeStyle="long" /><hr><fmt:formatDate value="${d}" pattern="yyyy-MM-dd / hh:mm" /><hr><c:forEach items="${snacks}" var="snack" varStatus="st"><div class="snack-row">  <div class="snack index">${st.index}</div>  <div class="snack index">${snack.name}</div>  <div class="snack index"><fmt:formatNumber value="${snack.price}" type="currency" ></fmt:formatNumber>  </div>  <div class="snack index"><fmt:formatDate value="${snack.date}" pattern="yyyy-MM-dd"  /></div></div></c:forEach></body></html>