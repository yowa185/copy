<%@ page contentType="text/html;charset=UTF-8" language="java" %><!DOCTYPE html><html><head>    <meta charset="UTF-8">    <title>단위변환</title></head><body><form action="unit-menu" method="post">    <div class = container>        <div>단위변환</div>        <div>변환할 값</div>        <div>            <input name="num" id="no"> <br>        </div>        <div>            <select name="unit">                <option value = "cm" > cm → inch</option>                <option value = "㎡" > ㎡ → 평</option>                <option value = "°C" > °C → °F</option>                <option value = "km/h" > km/h → mi/h</option>            </select> <br>        </div>        <div>            <button>확인</button>        </div>    </div></form></body></html>